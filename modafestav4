      estagio:     document.getElementById('estagio').value,
      origem:      'LP Moda Festa V2 - Alto Padrão',
      data:        new Date().toISOString()
    };

    try {
      await fetch(WEBHOOK_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
    } catch (err) {
